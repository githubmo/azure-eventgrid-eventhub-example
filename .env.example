# Documents the schema of the gitignored .env file at the repo root.
# Generate a real .env by running scripts/dump-env.sh after `pulumi up`.

# The stack uses Pulumi's passphrase secrets provider, so reading any
# output (including non-secret ones) requires the passphrase. Sourcing
# .env will export it for both Pulumi CLI calls and the dump-env script.
PULUMI_CONFIG_PASSPHRASE=

# Required by the Azure-Samples/.../eventgrid/topic walkthrough.
# Used as the subscription to target when constructing armresources /
# armeventgrid client factories.
AZURE_SUBSCRIPTION_ID=

# Optional. When set (any non-empty value), the linked sample skips
# its self-cleanup and leaves the resources it created in place so
# you can inspect them in the portal.
KEEP_RESOURCE=1

# Populated from Pulumi outputs by scripts/dump-env.sh.
# Consumed by the application code (uploader / consumer) once written.
AZURE_RESOURCE_GROUP=
AZURE_LOCATION=
STORAGE_ACCOUNT_NAME=
BLOB_CONTAINER_NAME=
EVENT_HUB_NAMESPACE_FQDN=
EVENT_HUB_NAME=
